# Database — PostgreSQL connection string
# בסביבה מקומית: postgresql://postgres:postgres@localhost:5432/ngo_manager
# בענן: תקבל URL מ-Supabase / Neon / Railway
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/ngo_manager"

# Anthropic Claude API
# הרשמה: https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."

# Email — Resend (שליחת מיילים ומכתבי הוקרה)
# הרשמה: https://resend.com
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@yourdomain.com"

# NextAuth — אבטחת session
# יצירת SECRET: openssl rand -base64 32
NEXTAUTH_SECRET="your-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# משתמש מנהל (המערכת היא single-user)
ADMIN_EMAIL="danny@ngo.org"
ADMIN_PASSWORD="your-strong-password"
